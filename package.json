{
  "name": "membrana",
  "productName": "Membrana",
  "version": "1.0.0",
  "description": "Membrana - Audio Analysis Desktop Application",
  "main": "dist-electron/main.js",
  "author": "druid",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron:start\"",
    "electron:start": "cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder",
    "build:installer": "npm run build && electron-builder",
    "build:electron": "tsc --project tsconfig.electron.json",
    "build:react": "vite build",
    "dist": "npm run build:electron && npm run build && electron-builder",
    "dist:win": "npm run build:electron && npm run build && electron-builder --config electron-builder.json --win",
    "release:exe": "\"C:\\Users\\%USERNAME%\\AppData\\Local\\Programs\\Membrana\\Membrana.exe\" --enable-logging --log-file=\"%APPDATA%\\Membrana\\logs\\app.log\" --verbose 2>&1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "daisyui": "^5.5.19",
    "fft-js": "^0.0.12",
    "fft.js": "^4.0.4",
    "react": "^18.2.0",
    "react-daisyui": "^5.0.5",
    "react-dom": "^18.2.0",
    "react-json-view": "^1.21.3",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.yourname.stopwatch",
    "productName": "Секундомер",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
